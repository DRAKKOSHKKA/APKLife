<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_main.xml — Главный layout приложения.
    Содержит SwipeRefreshLayout для pull-to-refresh и WebView.
    ProgressBar отображается во время загрузки Flask-сервера.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md3_background"
    tools:context=".MainActivity">

    <!-- SwipeRefreshLayout оборачивает WebView для pull-to-refresh -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefresh"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <WebView
            android:id="@+id/webView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <!-- Splash / Loading overlay — показывается пока Flask стартует -->
    <RelativeLayout
        android:id="@+id/splashOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/md3_background"
        android:visibility="visible">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:gravity="center"
            android:orientation="vertical">

            <FrameLayout
                android:layout_width="120dp"
                android:layout_height="120dp">

                <!-- Пульсирующий фон -->
                <View
                    android:id="@+id/pulseView"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_gravity="center"
                    android:background="@drawable/splash_circle" />

                <ImageView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_gravity="center"
                    android:src="@mipmap/ic_launcher"
                    android:elevation="4dp" />
            </FrameLayout>

            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/loadingIndicator"
                android:layout_width="140dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:indeterminate="true"
                app:indicatorColor="@color/md3_primary"
                app:trackColor="@color/md3_primary_container"
                app:trackThickness="4dp"
                app:trackCornerRadius="2dp"
                xmlns:app="http://schemas.android.com/apk/res-auto" />

            <TextView
                android:id="@+id/loadingText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/loading_server"
                android:textColor="@color/md3_on_surface_variant"
                android:textSize="13sp"
                android:letterSpacing="0.05"
                android:fontFamily="sans-serif-medium"
                android:textAllCaps="true" />

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:layout_centerHorizontal="true"
            android:layout_marginBottom="48dp"
            android:text="APKLife students-first"
            android:textColor="@color/md3_outline"
            android:textSize="12sp"
            android:fontFamily="sans-serif-light" />

    </RelativeLayout>

    <!-- Экран ошибки — показывается если Flask не удалось запустить -->
    <LinearLayout
        android:id="@+id/errorOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/md3_background"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚠️"
            android:textSize="48sp" />

        <TextView
            android:id="@+id/errorTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/error_title"
            android:textColor="@color/md3_error"
            android:textSize="18sp"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:id="@+id/errorMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/error_server_failed"
            android:textColor="@color/md3_on_surface_variant"
            android:textSize="14sp"
            android:gravity="center" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/retryButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/retry"
            style="@style/Widget.Material3.Button.TonalButton" />

    </LinearLayout>

</FrameLayout>
