<?xml version="1.0" encoding="utf-8"?>
<!--
    Темы приложения APKLife:
    Theme.APKLife — основная тема Material 3
    Theme.APKLife.Splash — тема для splash-экрана Android 12+
-->
<resources>
    <!-- Основная тема Material Design 3 (поддерживает Dynamic Colors) -->
    <style name="Theme.APKLife" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Оставляем пустой для автоматического использования Dynamic Colors -->
    </style>

    <!-- Тема для Splash Screen API (Android 12+) -->
    <style name="Theme.APKLife.Splash" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowSplashScreenBackground">?attr/colorSurface</item>
    </style>
</resources>
